{
  "name": "app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:baseline": "vite --port 4173 --strictPort",
    "dev:task": "vite --port 4181 --strictPort",
    "build": "vite build",
    "build:pages": "GITHUB_PAGES=true vite build",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run test && npm run build && npm run build:pages",
    "preview": "vite preview",
    "preview:baseline": "vite preview --port 4173 --strictPort",
    "preview:task": "vite preview --port 4181 --strictPort",
    "workspace:status": "node scripts/workspace-status.mjs",
    "workspace:baseline": "node scripts/workspace-status.mjs --baseline",
    "workspace:release": "node scripts/workspace-status.mjs --release"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "ogl": "^1.0.11",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "three": "^0.185.1",
    "vite": "6.4.2"
  }
}
